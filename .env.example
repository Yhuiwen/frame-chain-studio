FCS_WORKER_HEARTBEAT_SECONDS=10
FCS_WORKER_STALE_AFTER_SECONDS=45
FCS_WORKER_LEASE_SECONDS=30
FCS_WORKER_POLL_INTERVAL_SECONDS=1
FCS_WORKER_RETRY_BASE_SECONDS=2
FCS_WORKER_RETRY_MAX_SECONDS=300
FCS_WORKER_RETRY_JITTER_RATIO=0.2
FCS_WORKER_SUBMISSION_TIMEOUT_SECONDS=120
FCS_WORKER_JOB_TIMEOUT_SECONDS=1800
FCS_WORKER_CANCELLATION_TIMEOUT_SECONDS=120
FCS_WORKER_MAX_UNKNOWN_POLLS=3
FCS_WORKER_BATCH_SIZE=10
FCS_RESULT_ALLOWED_PRIVATE_HOSTS=127.0.0.1
FCS_RESULT_WORKER_LEASE_SECONDS=300
FCS_RESULT_CONNECT_TIMEOUT_SECONDS=10
FCS_RESULT_READ_TIMEOUT_SECONDS=60
FCS_RESULT_TOTAL_TIMEOUT_SECONDS=900
FCS_RESULT_MAX_IMAGE_BYTES=52428800
FCS_RESULT_MAX_VIDEO_BYTES=2147483648
FCS_RESULT_MAX_IMAGE_PIXELS=80000000
FCS_RESULT_DOWNLOAD_CHUNK_BYTES=1048576
FCS_RESULT_MAX_REDIRECTS=3
FCS_RESULT_MAX_ATTEMPTS=3
FCS_RESULT_RETRY_BASE_SECONDS=2
FCS_RESULT_RETRY_MAX_SECONDS=300
FCS_RESULT_RETRY_JITTER_RATIO=0.2
FCS_RESULT_TEMP_FILE_TTL_HOURS=24
FCS_FFPROBE_TIMEOUT_SECONDS=30
VITE_API_BASE_URL=
